{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCCGUB Governed Parameters",
  "type": "object",
  "required": ["governance", "finality"],
  "properties": {
    "governance": {
      "type": "object",
      "required": [
        "max_consecutive_proposals",
        "max_actions_per_agent_pct",
        "safety_change_min_signers",
        "genesis_change_min_signers",
        "max_authority_term_epochs",
        "authority_cooldown_epochs"
      ],
      "properties": {
        "max_consecutive_proposals": { "type": "integer", "minimum": 1 },
        "max_actions_per_agent_pct": { "type": "integer", "minimum": 1, "maximum": 100 },
        "safety_change_min_signers": { "type": "integer", "minimum": 1 },
        "genesis_change_min_signers": { "type": "integer", "minimum": 1 },
        "max_authority_term_epochs": { "type": "integer", "minimum": 1 },
        "authority_cooldown_epochs": { "type": "integer", "minimum": 0 }
      }
    },
    "finality": {
      "type": "object",
      "required": [
        "confirmation_depth",
        "max_finality_ms",
        "target_block_time_ms"
      ],
      "properties": {
        "confirmation_depth": { "type": "integer", "minimum": 1 },
        "max_finality_ms": { "type": "integer", "minimum": 0 },
        "target_block_time_ms": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
